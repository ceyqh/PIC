<UserControl x:Class="PIC.View.Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             mc:Ignorable="d" 
             xmlns:p="clr-namespace:PIC.Utilities"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid>
        <Grid HorizontalAlignment="Right">

            <!-- IMATGE BACKGROUND -->
            <Image Source="/Images/login_screen.png"  
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Stretch="UniformToFill"
                   Width="900"/>            
        </Grid>

        <Grid Background="White"
              Width="300"
              HorizontalAlignment="Left">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- LOGO -->
            <Image Grid.Row="0"
                   Source="/Images/logo_color2.png"
                   Margin="30"
                   Width="50"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Left"/>

            <Grid Grid.Row="1"
                  Margin="30">

                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <!-- TÍTOL NOM USUARI -->
                <TextBlock Text="Usuari: " 
                           Grid.Row="0"
                           Style="{StaticResource Fraktion_Dark_Font}" 
                           FontSize="12" 
                           Margin="0,0,0,10"/>

                <!-- CAMP NOM USUARI -->
                <TextBox Text="{Binding Usuari}"
                         Grid.Row="1"
                         Style="{StaticResource Main_TextBox}"
                         Height="30"/>

                <!-- TÍTOL CONTRASENYA -->
                <TextBlock Text="Contrasenya: " 
                           Grid.Row="3"
                           Style="{StaticResource Fraktion_Dark_Font}" 
                           FontSize="12" 
                           Margin="0,0,0,10"/>

                <!-- CAMP CONTRASENYA -->
                <PasswordBox p:PasswordHelper.BoundPassword="{Binding Contrasenya, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="4"
                             Style="{StaticResource Main_PasswordBox}"
                             Height="30"/>

                
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- MISSATGE ERROR -->
                    <TextBlock Text="{Binding TextError}"
                               Grid.Column="0"
                               TextWrapping="Wrap"
                               Margin="0, 0, 10, 0"
                               VerticalAlignment="Top"
                               Style="{StaticResource Fraktion_Red_Font}" 
                               FontSize="10"/>

                    <!-- BOTÓ ENTRAR -->
                    <Button Content="ENTRAR"
                            Grid.Column="1"
                            Command="{Binding Login_Click}"
                            Padding="10, 0"
                            Width="70"
                            Height="30"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Style="{StaticResource Accions_Button}"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- BOTÓ SORTIR -->
        <Button Style="{StaticResource Accions_Button}"
                Width="40"
                Height="30"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Click="Tancar_Click">

            <!-- IMATGE BOTÓ -->
            <Image Source="/Images/creu_tancar.png" 
                   Width="15" 
                   Height="15"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>
        </Button>
    </Grid>
</UserControl>
