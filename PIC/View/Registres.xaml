<UserControl x:Class="PIC.View.Registres"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             xmlns:vm="clr-namespace:PIC.ViewModel"
             xmlns:Menu="clr-namespace:PIC.Utilities"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1400">

    <UserControl.DataContext>
        <vm:RegistresVM/>
    </UserControl.DataContext>
    
    <Grid>
        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- APARTAT DELS BOTONS I SECCIONS DELS RESULTATS -->
                <Grid Grid.Row="0" 
                      Background="#a5a6af">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Margin="10">

                        <TextBlock Text="Mostrar:"
                                   Grid.Row="0"
                                   Margin="0, 0, 10, 0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource Fraktion_Dark_Font}"/>

                        <ComboBox SelectedValue="{Binding MostrarRegistres, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Content"
                                  Grid.Row="2"
                                  Style="{StaticResource Ordenar_ComboBox}"
                                  Width="200"
                                  Height="30">

                            <ComboBoxItem Content="TOTS"/>
                            <ComboBoxItem Content="PER ID PRÉSTEC"/>
                            <ComboBoxItem Content="PER ID DISPOSITIU"/>
                            <ComboBoxItem Content="PER ID CURS"/>
                            <ComboBoxItem Content="PER ID DEPARTAMENT"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal"
                                    Width="200"
                                    Margin="10, 0, 30, 0">

                            <TextBox Style="{StaticResource Main_TextBox}"
                                     Text="{Binding ParametreCercaRegistres, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding HabilitarCerca}"
                                     Height="30"
                                     Width="120"/>

                            <Button Content="CERCAR"
                                    Command="{Binding BuscarCommand}"
                                    IsEnabled="{Binding HabilitarCerca}"
                                    Padding="10, 0, 10, 0"
                                    Margin="10, 0, 0, 0"
                                    Width="70"
                                    Height="30"
                                    Style="{StaticResource Accions_Button}"/>
                        </StackPanel>

                        <TextBlock Text="Ordenar per:"
                                   Margin="0, 0, 10, 0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource Fraktion_Dark_Font}"/>

                        <ComboBox SelectedValue="{Binding OrdenarRegistres, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Content"
                                  Grid.Row="16"
                                  Style="{StaticResource Ordenar_ComboBox}"
                                  Width="200"
                                  Height="30"
                                  Padding="5, 0, 0, 0">

                            <ComboBoxItem Content="ID PRÉSTEC"/>
                            <ComboBoxItem Content="USUARI"/>
                            <ComboBoxItem Content="DATA ACCIÓ"/>
                            <ComboBoxItem Content="DATA RETORN"/>
                        </ComboBox>

                    </StackPanel>

                    <Grid Grid.Row="1"
                          Background="#131316">

                        <!-- TÍTOL -->
                        <TextBlock FontSize="12" 
                                   VerticalAlignment="Center"
                                   Text="{Binding TextCerca}"
                                   Style="{StaticResource Fraktion_Light_Font}" 
                                   Margin="10, 0, 10, 0"/>
                    </Grid>
                </Grid>

                <!-- APARTAT DEL RESULTATS -->
                <Grid Grid.Row="1" 
                      Background="White">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- USUARIS -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- HEADER USUARIS -->
                            <Grid Grid.Row="0"
                                  Background="#e8e9e9">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="0.75*"/>
                                    <ColumnDefinition Width="1.25*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="0.75*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="10, 0, 0, 0" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">ID_P</TextBlock>
                                </Grid>

                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">ACCIO</TextBlock>
                                </Grid>

                                <Grid Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">USUARI</TextBlock>
                                </Grid>

                                <Grid Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">DISPOSITIU</TextBlock>
                                </Grid>

                                <Grid Grid.Column="4" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">GRUP</TextBlock>
                                </Grid>
                                
                                <Grid Grid.Column="5" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">DATES</TextBlock>
                                </Grid>
                            </Grid>

                            <!-- LLISTAT USUARIS -->
                            <Grid Grid.Row="2">
                                <ListView ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                          ItemsSource="{Binding Registres}"
                                          Style="{StaticResource ListViewStyle}"
                                          ItemContainerStyle="{StaticResource ListViewStyleItem}">

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="0.75*"/>
                                                    <ColumnDefinition Width="1.25*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="0.75*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock FontSize="12"  
                                                           Grid.Column="0" 
                                                           Text="{Binding IdPrestec}" 
                                                           Style="{StaticResource Fraktion_Dark_Font}"
                                                           Margin="10,0,0,0"/>
                                                
                                                <TextBlock FontSize="12"  
                                                           Grid.Column="1" 
                                                           Text="{Binding Accio}" 
                                                           Style="{StaticResource Fraktion_Dark_Font}"/>

                                                <StackPanel Grid.Column="2" >
                                                    <TextBlock FontSize="12"  
                                                               Text="{Binding IdUsuari}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>

                                                    <TextBlock FontSize="12"                                                                
                                                               Text="{Binding NomUsuari}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" >
                                                    <TextBlock FontSize="12"  
                                                               Text="{Binding IdDispositiu}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>

                                                    <TextBlock FontSize="12"                                                                
                                                               Text="{Binding NomDispositiu}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="4" >
                                                    <TextBlock FontSize="12"  
                                                               Text="{Binding IdGrup}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>

                                                    <TextBlock FontSize="12"                                                                
                                                           Text="{Binding NomGrup}"
                                                           Style="{StaticResource Fraktion_Dark_Font}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="5" >
                                                    <TextBlock FontSize="12"  
                                                               Text="{Binding DataAccioFormatat}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>

                                                    <TextBlock FontSize="12"                                                                
                                                           Text="{Binding DataRetornFormatat}"
                                                           Style="{StaticResource Fraktion_Dark_Font}"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <local:MissatgeError DataContext="{Binding MissatgeError}" d:IsHidden="true"/>
    </Grid>
</UserControl>
