<UserControl x:Class="PIC.View.Home"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1400">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#e8e9e9">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0, 25, 0, 0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Border BorderBrush="#131316" BorderThickness="0, 0, 1, 0"></Border>
                            <Image Source="/Images/logo.png" HorizontalAlignment="Right" Margin="0, 0, 25, 0"></Image>
                        </Grid>

                        <Grid Grid.Column="1">
                            <Image Source="/Images/logo_campalans.png" HorizontalAlignment="Left" Margin="25, 0, 0, 0"></Image>
                        </Grid>
                    </Grid>
                </Grid>
                
                <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="1000">
                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}" TextWrapping="Wrap" TextAlignment="Center">Benvingut/da a PIC, el gestor de préstecs de material de l'Institut Rafael Campalans.</TextBlock>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">

        </Grid>
    </Grid>
</UserControl>
