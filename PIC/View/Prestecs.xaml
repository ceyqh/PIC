<UserControl x:Class="PIC.View.Prestecs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             xmlns:vm="clr-namespace:PIC.ViewModel"
             xmlns:Menu="clr-namespace:PIC.Utilities"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.DataContext>
        <vm:PrestecsVM/>
    </UserControl.DataContext>

    <Grid>
        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- APARTAT DELS BOTONS I SECCIONS DELS RESULTATS -->
                <Grid Grid.Row="0" 
                      Background="#a5a6af">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Margin="10">

                        <TextBlock Text="Mostrar:"
                                   Grid.Row="0"
                                   Margin="0, 0, 10, 0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource Fraktion_Dark_Font}"/>

                        <ComboBox SelectedValue="{Binding MostrarPrestecs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Content"
                                  Grid.Row="2"
                                  Style="{StaticResource Ordenar_ComboBox}"
                                  Width="200"
                                  Height="30">

                            <ComboBoxItem Content="TOTS"/>
                            <ComboBoxItem Content="PER ID PRÉSTEC"/>
                            <ComboBoxItem Content="PER ID DISPOSITIU"/>
                            <ComboBoxItem Content="PER ID USUARI"/>
                            <ComboBoxItem Content="EN CURS"/>
                            <ComboBoxItem Content="CADUCATS"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal"
                                    Width="200"
                                    Margin="10, 0, 30, 0">

                            <TextBox Style="{StaticResource Main_TextBox}"
                                     Text="{Binding ParametreCercaPrestecs, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding HabilitarCerca}"
                                     Height="30"
                                     Width="120"/>

                            <Button Content="CERCAR"
                                    Command="{Binding BuscarCommand}"
                                    IsEnabled="{Binding HabilitarCerca}"
                                    Padding="10, 0, 10, 0"
                                    Margin="10, 0, 0, 0"
                                    Width="70"
                                    Height="30"
                                    Style="{StaticResource Accions_Button}"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Background="#131316">
                        
                        <!-- TÍTOL -->
                        <TextBlock FontSize="12" 
                                   VerticalAlignment="Center"
                                   Text="{Binding TextCerca}"
                                   Style="{StaticResource Fraktion_Light_Font}" 
                                   Margin="10, 0, 10, 0"/>

                    </Grid>
                </Grid>

                <!-- APARTAT DEL RESULTATS -->
                <Grid Grid.Row="1" 
                      Background="White">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="272.73"/>
                        </Grid.ColumnDefinitions>

                        <!-- USUARIS -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- HEADER USUARIS -->
                            <Grid Grid.Row="0"
                                  Background="#e8e9e9">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="0.5*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="10, 0, 0, 0" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">ID</TextBlock>
                                </Grid>

                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">USUARI</TextBlock>
                                </Grid>

                                <Grid Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">DISPOSITIU</TextBlock>
                                </Grid>

                                <Grid Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">DATES</TextBlock>
                                </Grid>

                                <Grid Grid.Column="4" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">ESTAT</TextBlock>
                                </Grid>
                            </Grid>

                            <!-- LLISTAT USUARIS -->
                            <Grid Grid.Row="2">
                                <ListView ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                          ItemsSource="{Binding Prestecs}"
                                          SelectedItem="{Binding PrestecSeleccionat, Mode=TwoWay}"
                                          Style="{StaticResource ListViewStyle}"
                                          ItemContainerStyle="{StaticResource ListViewStyleItem}">

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="0.5*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock FontSize="12"  
                                                           Grid.Column="0" 
                                                           Text="{Binding Id}" 
                                                           Style="{StaticResource Fraktion_Dark_Font}"
                                                           Margin="10,0,0,0"/>

                                                <StackPanel Grid.Column="1" >
                                                    <TextBlock FontSize="12"  
                                                               Text="{Binding IdUsuari}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>

                                                    <TextBlock FontSize="12"                                                                
                                                               Text="{Binding NomUsuari}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" >
                                                    <TextBlock FontSize="12"  
                                                               Text="{Binding IdDispositiu}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>

                                                    <TextBlock FontSize="12"                                                                
                                                               Text="{Binding NomDispositiu}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Column="3" >
                                                    <TextBlock FontSize="12"  
                                                               Text="{Binding DataEntregaFormatat}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>

                                                    <TextBlock FontSize="12"                                                                
                                                               Text="{Binding DataRetornFormatat}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>
                                                </StackPanel>

                                                <TextBlock FontSize="12" 
                                                           Grid.Column="4" 
                                                           Text="{Binding Estat}"
                                                           Style="{StaticResource Fraktion_Dark_Font}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>

                        <!-- BOTONS -->
                        <StackPanel Grid.Column="2" 
                                    Background="#a5a6af">

                            <Grid Margin="0, 0, 0 , 0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Accions:"
                                           Grid.Row="0"
                                           Width="200"
                                           VerticalAlignment="Bottom"
                                           Style="{StaticResource Fraktion_Dark_Font}"/>
                                
                                <Button Content="AFEGIR PRÉSTEC"
                                        Grid.Row="2"
                                        Width="200"
                                        Style="{StaticResource Accions_Button}"
                                        Command="{Binding AfegirPrestecMenu_Click}"/>

                                <Button Content="EDITAR PRÉSTEC"
                                        Grid.Row="4"
                                        Width="200"
                                        Style="{StaticResource Accions_Button}"
                                        Command="{Binding EditarPrestecMenu_Click}"/>

                                <Button Content="FINALITZAR PRÉSTEC"
                                        Grid.Row="6"
                                        Width="200"
                                        Style="{StaticResource Accions_Button}"
                                        Command="{Binding FinalitzarPrestec_Click}"/>
                                
                                <Button Content="ESBORRAR PRÉSTEC"
                                        Grid.Row="8"
                                        Width="200"
                                        Style="{StaticResource Accions_Button}"
                                        Command="{Binding EsborrarMenu_Click}"/>


                                <TextBlock Text="Ordenar per:"
                                           Grid.Row="10"
                                           Width="200"
                                           VerticalAlignment="Bottom"
                                           Style="{StaticResource Fraktion_Dark_Font}"/>

                                <ComboBox SelectedValue="{Binding OrdenarPrestecs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Content"
                                          Grid.Row="12"
                                          Style="{StaticResource Ordenar_ComboBox}"
                                          Width="200"
                                          Height="30">

                                    <ComboBoxItem Content="ID"/>
                                    <ComboBoxItem Content="USUARI"/>
                                    <ComboBoxItem Content="DATA ENTREGA"/>
                                    <ComboBoxItem Content="DATA RETORN"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <local:MissatgeError DataContext="{Binding MissatgeError}" d:IsHidden="true"/>
        <local:AfegirPrestec DataContext="{Binding AfegirPrestec}" d:IsHidden="true"/>
        <local:EditarPrestec DataContext="{Binding EditarPrestec}" d:IsHidden="true"/>
        <local:ConfirmarEsborrar DataContext="{Binding ConfirmarEsborrar}" d:IsHidden="true"/>
    </Grid>
</UserControl>
