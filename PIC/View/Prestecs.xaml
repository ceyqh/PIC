<UserControl x:Class="PIC.View.Prestecs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             xmlns:vm="clr-namespace:PIC.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.DataContext>
        <vm:PrestecsVM/>
    </UserControl.DataContext>

    <Grid>
        <Grid>
            <DataGrid ItemsSource="{Binding Prestecs}" x:Name="dgPrestec" VerticalAlignment="Top" HorizontalAlignment="Left" Width="Auto" 
            AutoGenerateColumns="False" CanUserResizeColumns="True" CanUserAddRows="False" >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" IsReadOnly="True" Binding="{Binding Id}" Width="30"/>
                    <DataGridTextColumn Header="NomUsuari" IsReadOnly="True" Binding="{Binding NomUsuari}" Width="100"/>
                    <DataGridTextColumn Header="IdUsuari" IsReadOnly="True" Binding="{Binding IdUsuari}" Width="100"/>
                    <DataGridTextColumn Header="NomDispositiu" IsReadOnly="True" Binding="{Binding NomDispositiu}" Width="Auto"/>
                    <DataGridTextColumn Header="IdDispositiu" IsReadOnly="True" Binding="{Binding IdDispositiu}" Width="Auto"/>
                    <DataGridTextColumn Header="DataEntrega" IsReadOnly="True" Binding="{Binding DataEntrega}" Width="Auto"/>
                    <DataGridTextColumn Header="DataRetorn" IsReadOnly="True" Binding="{Binding DataRetorn}" Width="Auto"/>
                    <DataGridTextColumn Header="Retornat" IsReadOnly="True" Binding="{Binding Retornat}" Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
