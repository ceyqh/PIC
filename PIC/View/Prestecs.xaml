<UserControl x:Class="PIC.View.Prestecs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             xmlns:vm="clr-namespace:PIC.ViewModel"
             xmlns:Menu="clr-namespace:PIC.Utilities"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1400">

    <UserControl.DataContext>
        <vm:PrestecsVM/>
    </UserControl.DataContext>

    <Grid>
        <Grid>
            <!--// Base Grid //-->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!--// Navigation Panel //-->
            <Grid HorizontalAlignment="Left" 
                  Width="200" 
                  Background="#e8e9e9">

                <StackPanel Height="400" Width="200">

                    <!-- TOTS -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" 
                              Command="{Binding CanviarModeCercaCommand}"
                              CommandParameter="TOTS" 
                              IsChecked="True">
                        <Grid>
                            <TextBlock Text="TOTS" Style="{StaticResource Text_Sub_Menu_Button_Style}"/>
                        </Grid>
                    </Menu:Btn>

                    <!-- PER ID -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" 
                              Command="{Binding CanviarModeCercaCommand}"
                              CommandParameter="PER_ID">
                        <Grid>
                            <TextBlock Text="PER ID" Style="{StaticResource Text_Sub_Menu_Button_Style}"/>
                        </Grid>
                    </Menu:Btn>

                    <!-- PER CURS -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" 
                              Command="{Binding CanviarModeCercaCommand}"
                              CommandParameter="PER_CURS">
                        <Grid>
                            <TextBlock Text="PER CURS" Style="{StaticResource Text_Sub_Menu_Button_Style}"/>
                        </Grid>
                    </Menu:Btn>

                    <!-- PER DEPARTAMENT -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" 
                              Command="{Binding CanviarModeCercaCommand}"
                              CommandParameter="PER_DEPARTAMENT">
                        <Grid>
                            <TextBlock Text="PER DEPARTAMENT" Style="{StaticResource Text_Sub_Menu_Button_Style}"/>
                        </Grid>
                    </Menu:Btn>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- APARTAT DELS BOTONS I SECCIONS DELS RESULTATS -->
                <Grid Grid.Row="0" 
                      Background="#a5a6af">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Margin="10">

                        <!-- TÍTOL -->
                        <TextBlock FontSize="12" 
                                   Text="{Binding TitolPantalla}"
                                   Style="{StaticResource Fraktion_Dark_Font}" 
                                   Margin="0, 0, 10, 0"/>

                        <!-- INPUT -->
                        <TextBox VerticalAlignment="Center"
                                 Width="200" 
                                 Visibility="{Binding CercaVisibility}" 
                                 Text="{Binding ParametreCercaUsuaris, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0"/>

                        <!-- BUSCAR -->
                        <Button Content="BUSCAR"
                                Visibility="{Binding CercaVisibility}"
                                Command="{Binding BuscarCommand}"
                                Padding="10, 0, 10, 0"
                                Style="{StaticResource Accions_Button}"/>

                    </StackPanel>

                    <Grid Grid.Row="1"
                          Background="#131316">

                    </Grid>
                </Grid>

                <!-- APARTAT DEL RESULTATS -->
                <Grid Grid.Row="1" 
                      Background="White">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="272.73"/>
                        </Grid.ColumnDefinitions>

                        <!-- USUARIS -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- HEADER USUARIS -->
                            <Grid Grid.Row="0"
                                  Background="#e8e9e9">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="0.5*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="10, 0, 0, 0" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">ID</TextBlock>
                                </Grid>

                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">USUARI</TextBlock>
                                </Grid>

                                <Grid Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">DISPOSITIU</TextBlock>
                                </Grid>

                                <Grid Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">DATES</TextBlock>
                                </Grid>

                                <Grid Grid.Column="4" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">ESTAT</TextBlock>
                                </Grid>
                            </Grid>

                            <!-- LLISTAT USUARIS -->
                            <Grid Grid.Row="2">
                                <ListView ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                          ItemsSource="{Binding Prestecs}"
                                          SelectedItem="{Binding PrestecSeleccionat, Mode=TwoWay}"
                                          Style="{StaticResource ListViewStyle}"
                                          ItemContainerStyle="{StaticResource ListViewStyleItem}">

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="0.5*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock FontSize="12"  
                                                           Grid.Column="0" 
                                                           Text="{Binding Id}" 
                                                           Style="{StaticResource Fraktion_Dark_Font}"
                                                           Margin="10,0,0,0"/>

                                                <StackPanel Grid.Column="1" >
                                                    <TextBlock FontSize="12"  
                                                               Text="{Binding IdUsuari}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>

                                                    <TextBlock FontSize="12"                                                                
                                                               Text="{Binding NomUsuari}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" >
                                                    <TextBlock FontSize="12"  
                                                               Text="{Binding IdDispositiu}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>

                                                    <TextBlock FontSize="12"                                                                
                                                               Text="{Binding NomDispositiu}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Column="3" >
                                                    <TextBlock FontSize="12"  
                                                               Text="{Binding DataEntregaFormatat}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>

                                                    <TextBlock FontSize="12"                                                                
                                                               Text="{Binding DataRetornFormatat}"
                                                               Style="{StaticResource Fraktion_Dark_Font}"/>
                                                </StackPanel>

                                                <TextBlock FontSize="12" 
                                                           Grid.Column="4" 
                                                           Text="En curs"
                                                           Style="{StaticResource Fraktion_Dark_Font}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>

                        <!-- BOTONS -->
                        <StackPanel Grid.Column="2" 
                                    Background="#a5a6af">

                            <Grid Margin="0, 40, 0 , 0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>

                                <Button Content="AFEGIR PRÉSTEC"
                                        Grid.Row="0"
                                        Width="200"
                                        Style="{StaticResource Accions_Button}"
                                        Command="{Binding AfegirPrestecMenu_Click}"/>

                                <Button Content="EDITAR PRÉSTEC"
                                        Grid.Row="2"
                                        Width="200"
                                        Style="{StaticResource Accions_Button}"
                                        Command="{Binding EditarPrestecMenu_Click}"/>

                                <Button Content="FINALITZAR PRÉSTEC"
                                        Grid.Row="4"
                                        Width="200"
                                        Style="{StaticResource Accions_Button}"
                                        Command="{Binding FinalitzarPrestec_Click}"/>
                                
                                <Button Content="ESBORRAR PRÉSTEC"
                                        Grid.Row="6"
                                        Width="200"
                                        Style="{StaticResource Accions_Button}"
                                        Command="{Binding EsborrarMenu_Click}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <local:MissatgeError DataContext="{Binding MissatgeError}" d:IsHidden="true"/>
        <local:AfegirPrestec DataContext="{Binding AfegirPrestec}" d:IsHidden="true"/>
        <local:EditarPrestec DataContext="{Binding EditarPrestec}" d:IsHidden="true"/>
        <local:ConfirmarEsborrar DataContext="{Binding ConfirmarEsborrar}" d:IsHidden="true"/>
    </Grid>
</UserControl>
