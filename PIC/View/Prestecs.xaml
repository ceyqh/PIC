<UserControl x:Class="PIC.View.Prestecs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             xmlns:vm="clr-namespace:PIC.ViewModel"
             xmlns:Menu="clr-namespace:PIC.Utilities"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1400">

    <UserControl.DataContext>
        <vm:PrestecsVM/>
    </UserControl.DataContext>

    <Grid>
        <Grid>
            <!--// Base Grid //-->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!--// Navigation Panel //-->
            <Grid HorizontalAlignment="Left" Width="200" Background="#e8e9e9">

                <StackPanel Height="400" Width="200">

                    <!-- TOTS -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" 
                      Command="{Binding CanviarModeCercaCommand}"
                      CommandParameter="TOTS" 
                      IsChecked="True">
                        <Grid>
                            <TextBlock Text="TOTS" Style="{StaticResource Text_Sub_Menu_Button_Style}"/>
                        </Grid>
                    </Menu:Btn>

                    <!-- PER ID -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" 
                      Command="{Binding CanviarModeCercaCommand}"
                      CommandParameter="PER_ID">
                        <Grid>
                            <TextBlock Text="PER ID" Style="{StaticResource Text_Sub_Menu_Button_Style}" />
                        </Grid>
                    </Menu:Btn>

                    <!-- PER ID CURS -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" 
                      Command="{Binding CanviarModeCercaCommand}"
                      CommandParameter="PER_DISPOSITIU">
                        <Grid>
                            <TextBlock Text="PER DISPOSITIU" Style="{StaticResource Text_Sub_Menu_Button_Style}" />
                        </Grid>
                    </Menu:Btn>

                    <!-- PER DEPARTAMENT -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}"
                      Command="{Binding CanviarModeCercaCommand}"
                      CommandParameter="PER_CATEGORIA">
                        <Grid>
                            <TextBlock Text="PER CATEGORIA" Style="{StaticResource Text_Sub_Menu_Button_Style}" />
                        </Grid>
                    </Menu:Btn>

                    <!-- PER DEPARTAMENT -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}"
                              Command="{Binding CanviarModeCercaCommand}"
                              CommandParameter="PER_CURS">
                        <Grid>
                            <TextBlock Text="PER CURS" Style="{StaticResource Text_Sub_Menu_Button_Style}" />
                        </Grid>
                    </Menu:Btn>

                    <!-- PER DEPARTAMENT -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}"
                              Command="{Binding CanviarModeCercaCommand}"
                              CommandParameter="PER_DEPARTAMENT">
                        <Grid>
                            <TextBlock Text="PER DEPARTAMENT" Style="{StaticResource Text_Sub_Menu_Button_Style}" />
                        </Grid>
                    </Menu:Btn>
                </StackPanel>

            </Grid>

            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- APARTAT DELS BOTONS I SECCIONS DELS RESULTATS -->
                <Grid Grid.Row="0" Background="#a5a6af">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                        Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        Margin="10">

                        <!-- TÍTOL -->
                        <TextBlock FontSize="12" 
                           Text="{Binding TitolPantalla}"
                           Style="{StaticResource Fraktion_Dark_Font}" 
                           Margin="0, 0, 10, 0"/>

                        <!-- INPUT -->
                        <TextBox VerticalAlignment="Center"
                         Width="200" 
                         Visibility="{Binding CercaVisibility}" 
                         Text="{Binding ParametreCercaPrestecs, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0"/>

                        <!-- BUSCAR -->
                        <Button Name="inputBoto"
                        Content="BUSCAR"
                        Visibility="{Binding CercaVisibility}"
                        Command="{Binding BuscarCommand}"
                        Padding="10, 0, 10, 0"
                        Style="{StaticResource Accions_Button}"/>

                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">

                            <!-- BOTO AFEGIR ALUMNE -->
                            <Button Content="AFEGIR PRÉSTEC"
                                    Style="{StaticResource Accions_Button}"
                                    Command="{Binding AfegirPrestecMenu_Click}"/>
                        </Grid>

                        <Grid Grid.Column="1">

                            <!-- BOTO EDITAR -->
                            <Button Content="EDITAR PRÉSTEC"
                                    Style="{StaticResource Accions_Button}"
                                    Command="{Binding EditarPrestecMenu_Click}"/>

                        </Grid>

                        <Grid Grid.Column="2">

                            <!-- BOTO FINALITZAR -->
                            <Button Content="FINALITZAR PRÉSTEC"
                                    Style="{StaticResource Accions_Button}"
                                    Command="{Binding FinalitzarPrestec_Click}"/>

                        </Grid>

                        <Grid Grid.Column="3">

                            <!-- BOTO ESBORRAR -->
                            <Button Content="ESBORRAR PRÉSTEC"  
                                    Style="{StaticResource Accions_Button}"
                                    Command="{Binding EsborrarMenu_Click}"/>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- APARTAT DEL RESULTATS -->
                <Grid Grid.Row="1"
                      Background="#e8e9e9">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="10, 0, 0, 0" 
                              VerticalAlignment="Center">
                            
                            <TextBlock Text="ID"
                                       FontSize="12" 
                                       Style="{StaticResource Fraktion_Dark_Font}"/>
                        </Grid>

                        <Grid Grid.Column="1" 
                              VerticalAlignment="Center">

                            <TextBlock Text="USUARI"
                                       FontSize="12" 
                                       Style="{StaticResource Fraktion_Dark_Font}"/>
                        </Grid>

                        <Grid Grid.Column="2" 
                              VerticalAlignment="Center">
                            
                            <TextBlock Text="ID_USUARI"
                                       FontSize="12" 
                                       Style="{StaticResource Fraktion_Dark_Font}"/>
                        </Grid>

                        <Grid Grid.Column="3" 
                              VerticalAlignment="Center">

                            <TextBlock Text="DISPOSITIU"
                                       FontSize="12" 
                                       Style="{StaticResource Fraktion_Dark_Font}"/>
                        </Grid>

                        <Grid Grid.Column="4" 
                              VerticalAlignment="Center">

                            <TextBlock Text="ID_DISPOSITIU"
                                       FontSize="12" 
                                       Style="{StaticResource Fraktion_Dark_Font}"/>
                        </Grid>
                        
                        <Grid Grid.Column="5" 
                              VerticalAlignment="Center">

                            <TextBlock Text="DATA_ENTREGA"
                                       FontSize="12" 
                                       Style="{StaticResource Fraktion_Dark_Font}"/>
                        </Grid>
                        
                        <Grid Grid.Column="6" 
                              VerticalAlignment="Center">

                            <TextBlock Text="DATA_RETORN"
                                       FontSize="12" 
                                       Style="{StaticResource Fraktion_Dark_Font}"/>
                        </Grid>

                    </Grid>
                </Grid>

                <Grid Grid.Row="2">
                    <ListView ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              ItemsSource="{Binding Prestecs}"
                              SelectedItem="{Binding PrestecSeleccionat, Mode=TwoWay}"
                              Style="{StaticResource ListViewStyle}"
                              ItemContainerStyle="{StaticResource ListViewStyleItem}">

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"  
                                               FontSize="12"      
                                               Style="{StaticResource Fraktion_Dark_Font}"
                                               Text="{Binding Id}" 
                                               Margin="10,0,0,0"/>

                                    <TextBlock Grid.Column="1" 
                                               FontSize="12"  
                                               Style="{StaticResource Fraktion_Dark_Font}"
                                               Text="{Binding NomUsuari}"/>

                                    <TextBlock Grid.Column="2" 
                                               FontSize="12"  
                                               Style="{StaticResource Fraktion_Dark_Font}"
                                               Text="{Binding IdUsuari}"/>

                                    <TextBlock Grid.Column="3" 
                                               FontSize="12"  
                                               Style="{StaticResource Fraktion_Dark_Font}"
                                               Text="{Binding NomDispositiu}"/>
                                    
                                    <TextBlock Grid.Column="4" 
                                               FontSize="12"  
                                               Style="{StaticResource Fraktion_Dark_Font}"
                                               Text="{Binding IdDispositiu}"/>

                                    <StackPanel Grid.Column="5">
                                        <TextBlock FontSize="12"  
                                                   Style="{StaticResource Fraktion_Dark_Font}"
                                                   Text="{Binding DataEntrega}"/>

                                        <TextBlock FontSize="12"  
                                                   Style="{StaticResource Fraktion_Dark_Font}"
                                                   Text="{Binding DataRetorn}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="6" 
                                               FontSize="12"  
                                               Style="{StaticResource Fraktion_Dark_Font}"
                                               Text="{Binding DataRetorn}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>

        <local:MissatgeError DataContext="{Binding MissatgeError}" d:IsHidden="true"/>
        <local:AfegirPrestec DataContext="{Binding AfegirPrestec}" d:IsHidden="true"/>
        <local:EditarPrestec DataContext="{Binding EditarPrestec}" d:IsHidden="true"/>
        <local:ConfirmarEsborrar DataContext="{Binding ConfirmarEsborrar}" d:IsHidden="true"/>
    </Grid>
</UserControl>
