<UserControl x:Class="PIC.View.MissatgeError"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Background="#80000000"
          Visibility="{Binding EsVisible}">

        <Grid MaxWidth="500" MinWidth="300"
              Background="White"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Títol -->
            <Grid Background="#131316">
                <TextBlock Text="ERROR"
                           Style="{StaticResource Fraktion_Light_Font}"
                           Margin="20, 10, 20, 10"/>
            </Grid>

            <StackPanel Grid.Row="1" 
                        Margin="20, 10, 20, 0">

                <TextBlock Text="{Binding Missatge}"
                           Style="{StaticResource Fraktion_Dark_Font}" 
                           FontSize="12"
                           TextAlignment="Justify"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Botó -->
            <Button Grid.Row="2"
                    Content="D'ACORD"
                    Padding="10, 0, 10, 0"
                    Style="{StaticResource Accions_Button}"
                    HorizontalAlignment="Right"
                    Margin="20"
                    Command="{Binding TancarFinestra}"/>
        </Grid>
    </Grid>
</UserControl>
