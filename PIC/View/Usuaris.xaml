<UserControl x:Class="PIC.View.Usuaris"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             xmlns:vm="clr-namespace:PIC.ViewModel"
             xmlns:Menu="clr-namespace:PIC.Utilities"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1400">

    <UserControl.DataContext>
        <vm:UsuarisVM/>
    </UserControl.DataContext>
    
    <Grid>
        <Grid>
            <!--// Base Grid //-->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!--// Navigation Panel //-->
            <Grid HorizontalAlignment="Left" Width="200" Background="#e8e9e9">

                <StackPanel Height="400" Width="200">
                    
                    <!-- TOTS -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" Click="Tots_Click" IsChecked="True">
                        <Grid>
                            <TextBlock Text="TOTS" Style="{StaticResource Text_Sub_Menu_Button_Style}"/>
                        </Grid>
                    </Menu:Btn>

                    <!-- PER ID -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" Click="PerId_Click">
                        <Grid>
                            <TextBlock Text="PER ID" Style="{StaticResource Text_Sub_Menu_Button_Style}" />
                        </Grid>
                    </Menu:Btn>

                    <!-- PER ID CURS -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" Click="PerCurs_Click">
                        <Grid>
                            <TextBlock Text="PER CURS" Style="{StaticResource Text_Sub_Menu_Button_Style}" />
                        </Grid>
                    </Menu:Btn>

                    <!-- PER DEPARTAMENT -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" Click="PerDepartament_Click">
                        <Grid>
                            <TextBlock Text="PER DEPARTAMENT" Style="{StaticResource Text_Sub_Menu_Button_Style}" />
                        </Grid>
                    </Menu:Btn>

                </StackPanel>

            </Grid>

            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- APARTAT DELS BOTONS I SECCIONS DELS RESULTATS -->
                <Grid Grid.Row="0" Background="#a5a6af">
                    <StackPanel Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Margin="10">

                        <!-- TÍTOL -->
                        <TextBlock Name="usuarisTitol" 
                                   FontSize="12" 
                                   Style="{StaticResource Fraktion_Dark_Font}" 
                                   Margin="0, 0, 10, 0">USUARIS: TOTS</TextBlock>

                        <!-- INPUT -->
                        <TextBox Name="inputArea"
                                 VerticalAlignment="Center"
                                 Width="200" 
                                 Text="{Binding ParametreCerca, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,10,0"/>

                        <!-- BUSCAR -->
                        <Button Name="inputText"
                                Content="Buscar"
                                Width="100"
                                Click="Buscar_Click"/>

                        <!-- BOTO AFEGIR -->
                        <Button Name="afegirAlumne"
                                Content="Afegir alumne"
                                Margin="50, 0, 10, 0"
                                Click="AfegirAlumneMenu_Click"/>

                        <!-- BOTO AFEGIR -->
                        <Button Name="afegirProfessor"
                                Content="Afegir professor "
                                Margin="0, 0, 10, 0"
                                Click="AfegirProfessorMenu_Click"/>

                        <!-- BOTO EDITAR -->
                        <Button Name="editarUsuari"
                                Content="Editar"
                                Margin="0, 0, 10, 0"
                                Click="EditarUsuariMenu_Click"/>

                        <!-- BOTO ESBORRAR -->
                        <Button Name="esborrarUsuari"
                                Content="Esborrar"  
                                Click="EsborrarUsuariMenu_Click"/>

                    </StackPanel>
                </Grid>

                <!-- APARTAT DEL RESULTATS -->
                <Grid Grid.Row="1" Background="White">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="10, 0, 0, 0" VerticalAlignment="Center">
                            <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">
                                <Span x:Name="labelId">
                                    <Run>ID</Run>
                                </Span>
                            </TextBlock>
                        </Grid>

                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">NOM</TextBlock>
                        </Grid>

                        <Grid Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">
                                <Span x:Name="labelCognom">
                                    <Run>COGNOM</Run>
                                </Span>
                            </TextBlock>
                        </Grid>

                        <Grid Grid.Column="3" VerticalAlignment="Center">
                            <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">TIPUS</TextBlock>
                        </Grid>

                        <Grid Grid.Column="4" VerticalAlignment="Center">
                            <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">GRUP</TextBlock>
                        </Grid>

                        <Grid Grid.Column="5" VerticalAlignment="Center">
                            <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">
                                <Span x:Name="labelIdGrup">
                                    <Run>ID_GRUP</Run>
                                </Span>
                            </TextBlock>
                        </Grid>
                    </Grid>

                </Grid>

                <Grid Grid.Row="2">
                    <ListView x:Name="llistaUsuaris"
                              ItemsSource="{Binding Usuaris}"
                              Style="{StaticResource UsersListView}"
                              ItemContainerStyle="{StaticResource UsersListViewItem}">

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="166.67"/>
                                        <ColumnDefinition Width="166.67"/>
                                        <ColumnDefinition Width="166.67"/>
                                        <ColumnDefinition Width="166.67"/>
                                        <ColumnDefinition Width="166.67"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"  
                                               FontSize="12"                                              
                                               Text="{Binding Id}" 
                                               Margin="10,0,0,0"/>

                                    <TextBlock Grid.Column="1" 
                                               FontSize="12"  
                                               Text="{Binding Nom}"/>

                                    <TextBlock Grid.Column="2" 
                                               FontSize="12"  
                                               Text="{Binding Cognom}"/>

                                    <TextBlock Grid.Column="3" 
                                               FontSize="12"  
                                               Text="{Binding Tipus}"/>

                                    <TextBlock Grid.Column="4" 
                                               FontSize="12" 
                                               Text="{Binding Grup}"/>

                                    <TextBlock Grid.Column="5" 
                                               FontSize="12"  
                                               Text="{Binding IdGrup}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>

        <!-- MENU EDITAR -->
        <Grid x:Name="OverlayEditar"
              Visibility="Collapsed"
              Background="#80000000">

            <!-- POPUP -->
            <Border Width="300"
                    Background="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TÍTOL -->
                    <Grid Background="#131316" 
                          VerticalAlignment="Center">
                        
                        <TextBlock Text="EDITAR USUARI" 
                                   Style="{StaticResource Fraktion_Light_Font}" 
                                   FontSize="16" 
                                   Margin="20, 10, 20, 10"/>
                    </Grid>

                    <!-- NOM -->
                    <StackPanel Grid.Row="1" Margin="20, 10, 20, 0">
                        <TextBlock Text="NOM: " 
                                   Style="{StaticResource Fraktion_Dark_Font}" 
                                   FontSize="12" 
                                   Margin="0,0,0,10"/>

                        <TextBox Name="textNom" 
                                 Margin="0,0,0,20"  
                                 Style="{StaticResource Fraktion_Dark_Font_TextBox}"/>    
                    </StackPanel>

                    <!-- COGNOM -->
                    <StackPanel Grid.Row="2" 
                                Margin="20, 0, 20, 0">

                        <TextBlock Text="COGNOM: " 
                                   Style="{StaticResource Fraktion_Dark_Font}" 
                                   FontSize="12" 
                                   Margin="0,0,0,10"/>

                        <TextBox Name="textCognom" 
                                 Margin="0,0,0,20"                                 
                                 Style="{StaticResource Fraktion_Dark_Font_TextBox}"/>
                    </StackPanel>

                    <!-- GRUP -->
                    <StackPanel Grid.Row="3" 
                                Margin="20, 0, 20, 0">

                        <TextBlock Text="GRUP: " 
                                   Style="{StaticResource Fraktion_Dark_Font}" 
                                   FontSize="12" 
                                   Margin="0,0,0,10"/>

                        <ComboBox Name="cbGrups"
                                  SelectedValuePath="Id">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=Nom}" FontSize="12" Style="{StaticResource Fraktion_Dark_Font}"></TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- BOTONS -->
                    <StackPanel Grid.Row="4" 
                                Margin="20"
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right">

                        <Button Content="Guardar" 
                                Width="80" 
                                Margin="0,0,10,0"
                                Click="Guardar_Click"/>

                        <Button Content="Cancel·lar" 
                                Width="80" 
                                Click="TancarOverlay_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- MENU AFEGIR ALUMNE -->
        <Grid x:Name="OverlayAfegirAlumne"
              Visibility="Collapsed"
              Background="#80000000">

            <!-- POPUP -->
            <Border Width="300"
                    Background="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TÍTOL -->
                    <Grid Background="#131316" 
                          VerticalAlignment="Center">

                        <TextBlock Text="AFEGIR ALUMNE" 
                                   Style="{StaticResource Fraktion_Light_Font}" 
                                   FontSize="16" 
                                   Margin="20, 10, 20, 10"/>
                    </Grid>

                    <!-- NOM -->
                    <StackPanel Grid.Row="1" 
                                Margin="20, 10, 20, 0">
                        <TextBlock Text="NOM: " 
                                   Style="{StaticResource Fraktion_Dark_Font}" 
                                   FontSize="12" 
                                   Margin="0,0,0,10"/>

                        <TextBox Name="aa_textNom" 
                                 Margin="0,0,0,20"  
                                 Style="{StaticResource Fraktion_Dark_Font_TextBox}"/>
                    </StackPanel>

                    <!-- COGNOM -->
                    <StackPanel Grid.Row="2" 
                        Margin="20, 0, 20, 0">

                        <TextBlock Text="COGNOM: " 
                                   Style="{StaticResource Fraktion_Dark_Font}" 
                                   FontSize="12" 
                                   Margin="0,0,0,10"/>

                        <TextBox Name="aa_textCognom" 
                                 Margin="0,0,0,20"                                 
                                 Style="{StaticResource Fraktion_Dark_Font_TextBox}"/>
                    </StackPanel>

                    <!-- GRUP -->
                    <StackPanel Grid.Row="3" 
                        Margin="20, 0, 20, 0">

                        <TextBlock Text="CURS: " 
                                   Style="{StaticResource Fraktion_Dark_Font}" 
                                   FontSize="12" 
                                   Margin="0,0,0,10"/>

                        <ComboBox Name="cbCursos"
                                  SelectedValuePath="Id">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=Nom}" 
                                               FontSize="12" 
                                               Style="{StaticResource Fraktion_Dark_Font}">
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- BOTONS -->
                    <StackPanel Grid.Row="4" 
                                Margin="20"
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right">

                        <Button Content="Guardar" 
                                Width="80" 
                                Margin="0,0,10,0"
                                Click="AfegirAlumne_Click"/>

                        <Button Content="Cancel·lar" 
                                Width="80" 
                                Click="TancarOverlay_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- MENU AFEGIR ALUMNE -->
        <Grid x:Name="OverlayAfegirProfessor"
              Visibility="Collapsed"
              Background="#80000000">

            <!-- POPUP -->
            <Border Width="300"
                    Background="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TÍTOL -->
                    <Grid Background="#131316" 
                          VerticalAlignment="Center">

                        <TextBlock Text="AFEGIR PROFESSOR" 
                                   Style="{StaticResource Fraktion_Light_Font}" 
                                   FontSize="16" 
                                   Margin="20, 10, 20, 10"/>
                    </Grid>

                    <!-- NOM -->
                    <StackPanel Grid.Row="1" 
                                Margin="20, 10, 20, 0">
                        <TextBlock Text="NOM: " 
                                   Style="{StaticResource Fraktion_Dark_Font}" 
                                   FontSize="12" 
                                   Margin="0,0,0,10"/>

                        <TextBox Name="ap_textNom" 
                                 Margin="0,0,0,20"  
                                 Style="{StaticResource Fraktion_Dark_Font_TextBox}"/>
                    </StackPanel>

                    <!-- COGNOM -->
                    <StackPanel Grid.Row="2" 
                                Margin="20, 0, 20, 0">

                        <TextBlock Text="COGNOM: " 
                                   Style="{StaticResource Fraktion_Dark_Font}" 
                                   FontSize="12" 
                                   Margin="0,0,0,10"/>

                        <TextBox Name="ap_textCognom" 
                                 Margin="0,0,0,20"                                 
                                 Style="{StaticResource Fraktion_Dark_Font_TextBox}"/>
                    </StackPanel>

                    <!-- GRUP -->
                    <StackPanel Grid.Row="3" 
                                Margin="20, 0, 20, 0">

                        <TextBlock Text="DEPARTAMENT: " 
                                    Style="{StaticResource Fraktion_Dark_Font}" 
                                    FontSize="12" 
                                    Margin="0,0,0,10"/>

                        <ComboBox Name="cbDepartaments"
                                  SelectedValuePath="Id">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=Nom}" 
                                       FontSize="12" 
                                       Style="{StaticResource Fraktion_Dark_Font}">
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- BOTONS -->
                    <StackPanel Grid.Row="4" 
                                Margin="20"
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right">

                        <Button Content="Guardar" 
                                Width="80" 
                                Margin="0,0,10,0"
                                Click="AfegirProfessor_Click"/>

                        <Button Content="Cancel·lar" 
                                Width="80" 
                                Click="TancarOverlay_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
