<UserControl x:Class="PIC.View.FinalitzarCurs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Visibility="{Binding EsVisible}"
          Background="#80000000">

        <!-- POPUP -->
        <Grid Width="400"
              Background="White"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- TÍTOL -->
                <Grid Background="#C44545" 
                      VerticalAlignment="Center">

                    <TextBlock Text="ALERTA" 
                               Style="{StaticResource Fraktion_Light_Font}" 
                               FontSize="12" 
                               Margin="20, 10, 20, 10"/>
                </Grid>

                <!-- ALERTA -->
                <StackPanel Grid.Row="1" 
                            Margin="20, 10, 20, 0">

                    <TextBlock Style="{StaticResource Fraktion_Dark_Font}" 
                               FontSize="12" 
                               Margin="0,0,0,10"
                               TextWrapping="Wrap"
                               TextAlignment="Justify">
                        
                        Començar un nou curs comporta esborrar tots els cursos, alumnes i préstecs relacionats amb aquests alumnes. 
                        En cas de que hi hagués préstecs pendents de tancar per part d'algun alumne, es crearà un registre
                        informant d'aquesta excepció amb l'etiqueta "No finalitzat". Revisa que tots els préstecs estiguin finalitzats
                        (si s'ha retornat el dispositiu) abans de continuar.
                    </TextBlock>

                    <TextBlock Text="{Binding TextProces}"
                               Style="{StaticResource Fraktion_Dark_Font}" 
                               FontSize="12" 
                               Margin="0,20,0,10"
                               TextWrapping="Wrap"
                               TextAlignment="Justify"/>
                </StackPanel>

                <!-- CODI DE SEGUURETAT TEXTBOX -->
                <StackPanel Grid.Row="2" 
                            Margin="20, 10, 20, 0">
                    
                    <TextBlock Style="{StaticResource Fraktion_Dark_Font}" 
                               FontSize="12" 
                               Margin="0,20,0,10"
                               TextWrapping="Wrap"
                               TextAlignment="Justify">
    
                                Introdueix el codi que es mostra a continuació per confirmar: 
    
                                <!-- CODI DE SEGUURETAT -->
                                <Run Text="{Binding CodiSeguretat}" FontWeight="Bold"/>
                        </TextBlock>

                        <TextBox Text="{Binding CodiSeguretatTextBox}"
                                 Style="{StaticResource Main_TextBox}"
                                 Height="30"/>
                    </StackPanel>

                <StackPanel Grid.Row="3"
                    Margin="20, 20, 20, 0">

                    <TextBlock Style="{StaticResource Fraktion_Dark_Font}" 
                               FontSize="12" 
                               Margin="0,0,0,10"
                               TextWrapping="Wrap"
                               TextAlignment="Justify">   
                        Fitxer per importar els nous alumnes i cursos:
                    </TextBlock>

                    <Button Grid.Column="1" 
                            Content="{Binding BotoRutaFitxer}" 
                            Height="30"
                            Style="{StaticResource Arxiu_Button}"
                            Command="{Binding SeleccionarFitxer_Click}"/>

                </StackPanel>

                <!-- BOTONS -->
                <StackPanel Grid.Row="4"
                            Margin="20"
                            Height="25"
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right">

                    <Button Content="FINALITZAR"
                            Margin="0,0,10,0"
                            Padding="10, 0"
                            Style="{StaticResource Alerta_Button}"
                            Command="{Binding FinalitzarCurs_Click}"/>

                    <Button Content="CANCEL·LAR"
                            Padding="10, 0"
                            Style="{StaticResource Accions_Button}"
                            Command="{Binding TancarFinestra}"/>
                </StackPanel>
            </Grid>
        </Grid>

        <local:MissatgeError DataContext="{Binding MissatgeError}" d:IsHidden="true"/>
    </Grid>
</UserControl>
