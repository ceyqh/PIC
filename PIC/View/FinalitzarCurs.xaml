<UserControl x:Class="PIC.View.FinalitzarCurs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Visibility="{Binding EsVisible}"
          Background="#80000000">

        <!-- POPUP -->
        <Grid Width="400"
              Background="White"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- TÍTOL -->
                <Grid Background="#C44545" 
                      VerticalAlignment="Center">

                    <TextBlock Text="ALERTA" 
                               Style="{StaticResource Fraktion_Light_Font}" 
                               FontSize="12" 
                               Margin="20, 10, 20, 10"/>
                </Grid>

                <!-- ALERTA -->
                <StackPanel Grid.Row="1" 
                            Margin="20, 10, 20, 0">

                    <TextBlock Style="{StaticResource Fraktion_Dark_Font}" 
                               FontSize="12" 
                               Margin="0,0,0,10"
                               TextWrapping="Wrap"
                               TextAlignment="Justify">
                        
                        Finalitzar el curs implica esborrar tots els cursos, alumnes, préstecs i registres. Abans de continuar,
                        assegura't de que s'han exportat els registres del curs actual, de lo contrari, es perdran. Quan comenci
                        el procés, no es podrà aturar.
                    </TextBlock>

                    <TextBlock Text="{Binding TextProces}"
                               Style="{StaticResource Fraktion_Dark_Font}" 
                               FontSize="12" 
                               Margin="0,20,0,10"
                               TextWrapping="Wrap"
                               TextAlignment="Justify"/>

                    <TextBlock Style="{StaticResource Fraktion_Dark_Font}" 
                               FontSize="12" 
                               Margin="0,20,0,10"
                               TextWrapping="Wrap"
                               TextAlignment="Justify">
                        
                        Per seguretat, introdueix el codi que es mostra a continuació si vols continuar: 
                        
                        <!-- CODI DE SEGUURETAT -->
                        <Run Text="{Binding CodiSeguretat}" FontWeight="Bold"/>
                    </TextBlock>
                </StackPanel>

                <!-- CODI DE SEGUURETAT TEXTBOX -->
                <StackPanel Grid.Row="2" 
                            Margin="20, 10, 20, 0">

                    <TextBox Text="{Binding CodiSeguretatTextBox}"
                             Style="{StaticResource Main_TextBox}"/>
                </StackPanel>

                <!-- BOTONS -->
                <StackPanel Grid.Row="3"
                            Margin="20"
                            Height="25"
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right">

                    <Button Content="FINALITZAR"
                            Margin="0,0,10,0"
                            Padding="10, 0"
                            Style="{StaticResource Alerta_Button}"
                            Command="{Binding FinalitzarCurs_Click}"/>

                    <Button Content="CANCEL·LAR"
                            Padding="10, 0"
                            Style="{StaticResource Accions_Button}"
                            Command="{Binding TancarFinestra}"/>
                </StackPanel>
            </Grid>
        </Grid>

        <local:MissatgeError DataContext="{Binding MissatgeError}" d:IsHidden="true"/>
    </Grid>
</UserControl>
