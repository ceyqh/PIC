<UserControl x:Class="PIC.View.Departaments"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             xmlns:vm="clr-namespace:PIC.ViewModel"
             xmlns:Menu="clr-namespace:PIC.Utilities"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1400">

    <UserControl.DataContext>
        <vm:DepartamentsVM/>
    </UserControl.DataContext>

    <Grid>
        <Grid>
            <!--// Base Grid //-->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!--// Navigation Panel //-->
            <Grid HorizontalAlignment="Left" Width="200" Background="#e8e9e9">

                <StackPanel Height="400" Width="200">

                    <!-- TOTS -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" 
                              Command="{Binding CanviarModeCercaCommand}"
                              CommandParameter="TOTS" 
                              IsChecked="True">
                        <Grid>
                            <TextBlock Text="TOTS" Style="{StaticResource Text_Sub_Menu_Button_Style}"/>
                        </Grid>
                    </Menu:Btn>

                    <!-- PER ID -->
                    <Menu:Btn Style="{StaticResource Sub_Menu_Button}" 
                              Command="{Binding CanviarModeCercaCommand}"
                              CommandParameter="PER_ID">
                        <Grid>
                            <TextBlock Text="PER ID" Style="{StaticResource Text_Sub_Menu_Button_Style}" />
                        </Grid>
                    </Menu:Btn>

                </StackPanel>

            </Grid>

            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- APARTAT DELS BOTONS I SECCIONS DELS RESULTATS -->
                <Grid Grid.Row="0" 
                      Background="#a5a6af">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Margin="10">

                        <!-- TÍTOL -->
                        <TextBlock FontSize="12" 
                                   Text="{Binding TitolPantalla}"
                                   Style="{StaticResource Fraktion_Dark_Font}" 
                                   Margin="0, 0, 10, 0"/>

                        <!-- INPUT -->
                        <TextBox VerticalAlignment="Center"
                                 Width="200" 
                                 Visibility="{Binding CercaVisibility}" 
                                 Text="{Binding ParametreCercaDepartaments, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,10,0"/>

                        <!-- BUSCAR -->
                        <Button Content="BUSCAR"
                                Visibility="{Binding CercaVisibility}"
                                Command="{Binding BuscarCommand}"
                                Padding="10, 0, 10, 0"
                                Style="{StaticResource Accions_Button}"/>

                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">

                            <!-- BOTO AFEGIR PROFESSOR -->
                            <Button Content="AFEGIR DEPARTAMENT"
                                    Style="{StaticResource Accions_Button}"
                                    Command="{Binding AfegirDepartamentMenu_Click}"/>
                        </Grid>

                        <Grid Grid.Column="1">

                            <!-- BOTO EDITAR -->
                            <Button Content="EDITAR DEPARTAMENT"
                                    Style="{StaticResource Accions_Button}"
                                    Command="{Binding EditarDepartamentMenu_Click}"/>

                        </Grid>

                        <Grid Grid.Column="2">

                            <!-- BOTO ESBORRAR -->
                            <Button Content="ESBORRAR DEPARTAMENT"  
                                    Style="{StaticResource Accions_Button}"
                                    Command="{Binding EsborrarDepartamentMenu_Click}"/>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- APARTAT DEL RESULTATS -->
                <Grid Grid.Row="1" 
                      Background="White">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- CURSOS -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- HEADER CURSOS -->
                            <Grid Grid.Row="0"
                                  Background="#e8e9e9">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="10, 0, 0, 0" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">ID</TextBlock>
                                </Grid>

                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">NOM</TextBlock>
                                </Grid>
                            </Grid>

                            <!-- LLISTAT CURSOS -->
                            <Grid Grid.Row="2">
                                <ListView ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                          ItemsSource="{Binding Departaments}"
                                          SelectedItem="{Binding DepartamentSeleccionat, Mode=TwoWay}"
                                          Style="{StaticResource ListViewStyle}"
                                          ItemContainerStyle="{StaticResource ListViewStyleItem}">

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock FontSize="12" 
                                                           Grid.Column="0" 
                                                           Text="{Binding Id}" 
                                                           Style="{StaticResource Fraktion_Dark_Font}"
                                                           Margin="10,0,0,0"/>

                                                <TextBlock FontSize="12" 
                                                           Grid.Column="1" 
                                                           Text="{Binding Nom}"
                                                           Style="{StaticResource Fraktion_Dark_Font}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>

                        <!-- USUARIS -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- HEADER CURSOS -->
                            <Grid Grid.Row="0"
                                  Background="#c5c6cd">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="10, 0, 0, 0" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">ID</TextBlock>
                                </Grid>

                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">NOM</TextBlock>
                                </Grid>

                                <Grid Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Style="{StaticResource Fraktion_Dark_Font}">COGNOM</TextBlock>
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="1"
                                  Background="#e8e9e9">

                                <ListView ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                          ItemsSource="{Binding Usuaris}"
                                          Style="{StaticResource ListViewStyle}"
                                          ItemContainerStyle="{StaticResource ListViewStyleItemSubmenu}"
                                          Background="#e8e9e9">

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock FontSize="12" 
                                                           Grid.Column="0" 
                                                           Text="{Binding Id}" 
                                                           Style="{StaticResource Fraktion_Dark_Font}"
                                                           Margin="10,0,0,0"/>

                                                <TextBlock FontSize="12" 
                                                           Grid.Column="1" 
                                                           Text="{Binding Nom}"
                                                           Style="{StaticResource Fraktion_Dark_Font}"/>

                                                <TextBlock FontSize="12" 
                                                           Grid.Column="2" 
                                                           Text="{Binding Cognom}"
                                                           Style="{StaticResource Fraktion_Dark_Font}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <local:MissatgeError DataContext="{Binding MissatgeError}" d:IsHidden="true"/>
        <local:AfegirDepartament DataContext="{Binding AfegirDepartament}" d:IsHidden="true"/>
        <local:EditarDepartament DataContext="{Binding EditarDepartament}" d:IsHidden="true"/>
        <local:ConfirmarEsborrar DataContext="{Binding ConfirmarEsborrar}" d:IsHidden="true"/>
    </Grid>
</UserControl>
