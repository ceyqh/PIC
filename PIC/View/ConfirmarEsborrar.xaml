<UserControl x:Class="PIC.View.ConfirmarEsborrar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIC.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Background="#80000000"
            Visibility="{Binding EsVisible}">

        <Grid MaxWidth="500" MinWidth="300"
              Background="White"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Títol -->
            <Grid Background="{Binding ColorFons}">
                <TextBlock Text="ALERTA"
                   Style="{StaticResource Fraktion_Light_Font}"
                   Margin="20, 10, 20, 10"/>
            </Grid>

            <StackPanel Grid.Row="1" 
                        Margin="20, 10, 20, 0">

                <TextBlock x:Name="missatgeEsborrar" 
                           Text="{Binding Missatge}"
                           Style="{StaticResource Fraktion_Dark_Font}" 
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Botons -->
            <StackPanel Grid.Row="4"
                        Margin="20"
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right">

                <Button Content="{Binding TextBoto}"
                        Padding="10, 0, 10, 0"
                        Style="{StaticResource Alerta_Button}"
                        Margin="0,0,10,0"
                        Command="{Binding Esborrar_Click}"/>

                <Button Content="CANCEL·LAR"
                        Padding="10, 0, 10, 0"
                        Style="{StaticResource Accions_Button}"
                        Command="{Binding TancarFinestra}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
