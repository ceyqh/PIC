<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    
    <!-- BOTONS DEL MENÚ PRINCIPAL -->
    <Style x:Key="Main_Menu_Button" TargetType="RadioButton">

        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">

                    <Grid x:Name="GridArea" Height="40" Width="230">

                        <Grid.Background>
                            <SolidColorBrush x:Name="GridBackground"
                                         Color="#131316"/>
                        </Grid.Background>

                        <Grid>
                            <ContentPresenter/>
                        </Grid>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="GridArea" Property="Background" Value="#bbbbbb"/>
                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background" TargetName="GridArea" Value="#e8e9e9"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <!-- BOTONS DEL SUBMENÚ  -->
    <Style x:Key="Sub_Menu_Button" TargetType="RadioButton">

        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">

                    <Grid x:Name="GridArea" Height="40" Width="230">

                        <Grid.Background>
                            <SolidColorBrush x:Name="GridBackground"
                                     Color="#e8e9e9"/>
                        </Grid.Background>

                        <Grid>
                            <ContentPresenter/>
                        </Grid>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="GridArea" Property="Background" Value="#bbbbbb"/>
                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background" TargetName="GridArea" Value="#606064"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <ImageBrush x:Key="close_app_def" ImageSource="/Images/shutdown_def.png" Stretch="None" />

    <ImageBrush x:Key="close_app_mo" ImageSource="/Images/shutdown_mo.png" Stretch="None" />

    <!-- BOTONS DE SORTIR -->
    <Style x:Key="ExitApp" TargetType="{x:Type Button}">

        <Setter Property="Height" Value="40" />
        <Setter Property="Width" Value="40" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="0,15,15,0" />

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="{x:Type Button}">

                    <Border x:Name="GridArea" BorderThickness="0" Background="{StaticResource close_app_def}">

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter Property="Background" TargetName="GridArea" Value="{StaticResource close_app_mo}" />

                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">

                            <Setter Property="Background" TargetName="GridArea" Value="{StaticResource close_app_mo}" />

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>

    <!-- BOTONS ACCIONS -->
    <Style x:Key="Accions_Button" TargetType="Button">

        <Setter Property="Foreground" Value="#e8e9e9"/>
        <Setter Property="Background" Value="#131316"/>
        <Setter Property="BorderThickness" Value="0"/>


        <Setter Property="FontFamily" Value="/PIC;component/Fonts/#PP Fraktion Mono"/>
        <Setter Property="FontSize" Value="12"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <Grid x:Name="GridArea"
                            Background="{TemplateBinding Background}">

                        <ContentPresenter HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="{TemplateBinding Padding}"/>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="GridArea" Property="Background" Value="#606064"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BOTÓ ALERTA -->
    <Style x:Key="Alerta_Button" TargetType="Button">

        <Setter Property="Foreground" Value="#e8e9e9"/>
        <Setter Property="Background" Value="#C44545"/>
        <Setter Property="BorderThickness" Value="0"/>


        <Setter Property="FontFamily" Value="/PIC;component/Fonts/#PP Fraktion Mono"/>
        <Setter Property="FontSize" Value="12"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <Grid x:Name="GridArea"
                            Background="{TemplateBinding Background}">

                        <ContentPresenter HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="{TemplateBinding Padding}"/>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="GridArea" Property="Background" Value="#eb6c6c"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BOTÓ CONFIRMAR -->
    <Style x:Key="Confirmar_Button" TargetType="Button">

        <Setter Property="Foreground" Value="#e8e9e9"/>
        <Setter Property="Background" Value="#1fb9f9"/>
        <Setter Property="BorderThickness" Value="0"/>


        <Setter Property="FontFamily" Value="/PIC;component/Fonts/#PP Fraktion Mono"/>
        <Setter Property="FontSize" Value="12"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <Grid x:Name="GridArea"
                        Background="{TemplateBinding Background}">

                        <ContentPresenter HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="{TemplateBinding Padding}"/>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="GridArea" Property="Background" Value="#5bcdfc"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>