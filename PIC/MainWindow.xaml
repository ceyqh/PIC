<Window x:Class="PIC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PIC"
        xmlns:vm="clr-namespace:PIC.ViewModel"
        xmlns:v="clr-namespace:PIC.View"
        xmlns:Menu="clr-namespace:PIC.Utilities" 
        mc:Ignorable="d"
        Title="PIC"
        Height="600"
        Width="850"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent">

    <Window.DataContext>
        <vm:NavigationVM/>
    </Window.DataContext>

    <Grid>
        <!--// Window Border //-->
        <Border Background="#212529"/>
        <Grid>
            <!--// Base Grid //-->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="228" />
                <ColumnDefinition Width="622" />
            </Grid.ColumnDefinitions>

            <!--// Navigation Panel //-->
            <Grid HorizontalAlignment="Left"
                  Width="228">
                <Border Background="#272B2F"/>

                <StackPanel Height="400"
                            Width="228">

                    <!--// HOME //-->
                    <Menu:Btn Style="{StaticResource BtnStyle}" Command="{Binding HomeCommand}" IsChecked="True">
                        <Grid>
                            <Image Source="Images/icona_prova.png" Style="{StaticResource Image_Style}" />

                            <TextBlock Text="Home" Style="{StaticResource Text_Style}" />
                        </Grid>
                    </Menu:Btn>

                    <!--// PRESTECS //-->
                    <Menu:Btn Style="{StaticResource BtnStyle}" Command="{Binding PrestecsCommand}">
                        <Grid>
                            <Image Source="Images/icona_prova.png" Style="{StaticResource Image_Style}" />
                            <TextBlock Text="Préstecs" Style="{StaticResource Text_Style}" />
                        </Grid>
                    </Menu:Btn>


                    <!--// DISPOSITIUS //-->
                    <Menu:Btn Style="{StaticResource BtnStyle}" Command="{Binding DispositiusCommand}">
                        <Grid>
                            <Image Source="Images/icona_prova.png" Style="{StaticResource Image_Style}" />
                            <TextBlock Text="Dispositius" Style="{StaticResource Text_Style}" />
                        </Grid>
                    </Menu:Btn>

                    <!--// CATEGORIES //-->
                    <Menu:Btn Style="{StaticResource BtnStyle}" Command="{Binding CategoriesCommand}">
                        <Grid>
                            <Image Source="Images/icona_prova.png" Style="{StaticResource Image_Style}" />
                            <TextBlock Text="Categories" Style="{StaticResource Text_Style}" />
                        </Grid>
                    </Menu:Btn>

                    <!--// USUARIS //-->
                    <Menu:Btn Style="{StaticResource BtnStyle}" Command="{Binding UsuarisCommand}">
                        <Grid>
                            <Image Source="Images/icona_prova.png" Style="{StaticResource Image_Style}" />
                            <TextBlock Text="Usuaris" Style="{StaticResource Text_Style}" />
                        </Grid>
                    </Menu:Btn>

                    <!--// CURSOS //-->
                    <Menu:Btn Style="{StaticResource BtnStyle}" Command="{Binding CursosCommand}">
                        <Grid>
                            <Image Source="Images/icona_prova.png" Style="{StaticResource Image_Style}" />
                            <TextBlock Text="Cursos" Style="{StaticResource Text_Style}" />
                        </Grid>
                    </Menu:Btn>

                    <!--// DEPARTAMENTS //-->
                    <Menu:Btn Style="{StaticResource BtnStyle}" Command="{Binding DepartamentsCommand}">
                        <Grid>
                            <Image Source="Images/icona_prova.png" Style="{StaticResource Image_Style}" />
                            <TextBlock Text="Departaments" Style="{StaticResource Text_Style}" />
                        </Grid>
                    </Menu:Btn>

                </StackPanel>

            </Grid>

            <Grid Grid.Column="1">
                <ContentControl x:Name="Page" Content="{Binding CurrentView}"/>
            </Grid>

        </Grid>
        <Button x:Name="Close" Style="{StaticResource ExitApp}" Click="Close_Click"/>
    </Grid>
</Window>
