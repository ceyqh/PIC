<Window x:Class="PIC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PIC"
        xmlns:vm="clr-namespace:PIC.ViewModel"
        xmlns:v="clr-namespace:PIC.View"
        xmlns:Menu="clr-namespace:PIC.Utilities" 
        mc:Ignorable="d"
        Title="PIC"
        Height="600"
        Width="1200"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent">

    <Window.DataContext>
        <vm:NavigationVM/>
        <!-- Ara binda a la MainVM -->
    </Window.DataContext>

    <Grid>
        <!-- Aquest ContentControl intercanvia LoginView per MainAppView -->
        <ContentControl Content="{Binding CurrentView}"/>
    </Grid>
</Window>
